{
  "id": "pci-dss-4",
  "name": "PCI DSS 4.0",
  "description": "Payment Card Industry Data Security Standard v4.0",
  "controls": [
    {
      "id": "pci-1-1",
      "framework": "PCI DSS 4.0",
      "family": "Network Security Controls",
      "family_id": "REQ-1",
      "control_id": "1.1",
      "name": "Install and Maintain Network Security Controls",
      "description": "Processes and mechanisms for installing and maintaining network security controls are defined and understood.",
      "implementation_guidance": [
        "Document firewall policies",
        "Define allowed traffic flows",
        "Review rules semi-annually",
        "Implement change management for rules"
      ],
      "audit_evidence": [
        "Firewall policy",
        "Rule review records",
        "Network diagrams",
        "Change logs"
      ],
      "risk_addressed": [
        "Unauthorized network access",
        "Data breach"
      ],
      "priority": "high",
      "mappings": {
        "nist_800_53": [
          "SC-7"
        ],
        "iso_27001": [
          "A.8.20"
        ],
        "cis_v8": [
          "4.4"
        ]
      },
      "related_controls": [
        "1.2",
        "1.3",
        "1.4"
      ],
      "references": [
        "https://www.pcisecuritystandards.org"
      ]
    },
    {
      "id": "pci-2-2",
      "framework": "PCI DSS 4.0",
      "family": "Secure Configurations",
      "family_id": "REQ-2",
      "control_id": "2.2",
      "name": "System Components are Configured and Managed Securely",
      "description": "System components are configured and managed securely by applying industry-accepted hardening standards.",
      "implementation_guidance": [
        "Apply CIS benchmarks",
        "Remove default accounts",
        "Disable unnecessary services",
        "Document configurations"
      ],
      "audit_evidence": [
        "Hardening standards",
        "Configuration scans",
        "Default account removal",
        "Service inventory"
      ],
      "risk_addressed": [
        "Misconfigurations",
        "Default credentials",
