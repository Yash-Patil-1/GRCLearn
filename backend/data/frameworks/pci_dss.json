          "4.1"
        ]
      },
      "related_controls": [
        "2.1",
        "2.3"
      ],
      "references": [
        "https://www.pcisecuritystandards.org"
      ]
    },
    {
      "id": "pci-3-4",
      "framework": "PCI DSS 4.0",
      "family": "Protect Stored Account Data",
      "family_id": "REQ-3",
      "control_id": "3.4",
      "name": "Render PAN Unreadable Anywhere it is Stored",
      "description": "PAN is rendered unreadable anywhere it is stored using strong cryptography.",
      "implementation_guidance": [
        "Encrypt PAN with AES-256",
        "Implement tokenization",
        "Use one-way hashes where appropriate",
        "Manage encryption keys securely"
      ],
      "audit_evidence": [
        "Encryption configuration",
        "Tokenization system",
        "Key management procedures",
        "Storage scan results"
      ],
      "risk_addressed": [
        "Cardholder data exposure",
        "Compliance violation"
      ],
      "priority": "high",
      "mappings": {
        "nist_800_53": [
          "SC-28"
        ],
        "iso_27001": [
          "A.8.24"
        ],
        "cis_v8": [
          "3.11"
        ]
      },
      "related_controls": [
        "3.1",
        "3.5",
        "3.6"
      ],
      "references": [
        "https://www.pcisecuritystandards.org"
      ]
    },
    {
      "id": "pci-4-1",
      "framework": "PCI DSS 4.0",
      "family": "Protect Data in Transit",
      "family_id": "REQ-4",
      "control_id": "4.1",
      "name": "Strong Cryptography Protects Cardholder Data During Transmission",
      "description": "Strong cryptography and security protocols protect cardholder data during transmission over open networks.",
      "implementation_guidance": [
        "Use TLS 1.2+ for all transmissions",
        "Disable weak protocols",
        "Implement certificate management",
        "Monitor for downgrade attacks"
      ],
      "audit_evidence": [
