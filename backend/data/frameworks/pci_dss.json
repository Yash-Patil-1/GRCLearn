        "Protocol scan results",
        "Certificate inventory",
        "Monitoring records"
      ],
      "risk_addressed": [
        "Data interception",
        "Man-in-the-middle",
        "Eavesdropping"
      ],
      "priority": "high",
      "mappings": {
        "nist_800_53": [
          "SC-8"
        ],
        "iso_27001": [
          "A.8.24"
        ],
        "cis_v8": [
