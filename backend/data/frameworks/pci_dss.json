        "Define access by job function",
        "Review access semi-annually",
        "Document access decisions"
      ],
      "audit_evidence": [
        "Access control policy",
        "Role definitions",
        "Review records",
        "Access matrices"
      ],
      "risk_addressed": [
        "Unauthorized data access",
        "Insider threat",
        "Compliance violation"
      ],
      "priority": "high",
      "mappings": {
