      "id": "pci-6-3",
      "framework": "PCI DSS 4.0",
      "family": "Develop Secure Systems",
      "family_id": "REQ-6",
      "control_id": "6.3",
      "name": "Security Vulnerabilities are Identified and Addressed",
      "description": "Security vulnerabilities are identified and addressed in a timely manner.",
