      "family": "Principles",
      "family_id": "ART",
      "control_id": "Art.5",
      "name": "Principles Relating to Processing of Personal Data",
      "description": "Personal data shall be processed lawfully, fairly, transparently, with purpose limitation, data minimization, accuracy, storage limitation, and integrity.",
      "implementation_guidance": [
        "Define lawful basis for each processing activity",
        "Implement data minimization",
        "Set retention periods",
        "Ensure accuracy of data"
      ],
      "audit_evidence": [
